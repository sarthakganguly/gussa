# Sovereign Vault (Gussa) - Environment Configuration
# Strictly Local - Zero-Cloud Policy

# App Configuration
VITE_APP_NAME="Sovereign Vault"
VITE_APP_ENV=development

# Database Settings (Local RxDB)
# No external DB_HOST or credentials allowed.
VITE_RXDB_NAME=gussa_vault
VITE_RXDB_PASSWORD_SEED= # Used for internal AES-GCM encryption seed

# AI Configuration (Android AICore)
# Local inference only. No API keys allowed.
VITE_USE_LOCAL_AI=true
